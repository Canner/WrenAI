bigquery.project-id=
bigquery.dataset-id=
bigquery.credentials-key=
# Postgres connection info consumed by host-side helper scripts that call the
# ibis connector. If ibis-server runs inside docker-compose, `postgres:5432`
# is usually correct because the connector resolves the database from inside
# the Docker network. If you instead run the connector stack on the host, use
# the host-side published address such as `localhost:5432` or `localhost:9432`.
postgres.host=postgres
postgres.port=5432
postgres.database=test
postgres.user=postgres
postgres.password=postgres
