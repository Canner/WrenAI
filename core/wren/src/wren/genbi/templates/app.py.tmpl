"""GenBI data app: {name}

Generated by `wren genbi create`. Edit freely — saves hot-reload in place.

Panel decision axis — pick by whether the query is *cube-expressible*:

* Cube-expressible (measures + dimensions + filters over one cube) → use
  ``cube_panel``. Bind widgets to the spec for interactive dimension/filter
  switching; every reachable query stays governed by construction.
* Not cube-expressible (window functions, cross-cube joins, row-level detail)
  → use ``raw_panel``. It is dry-plan validated and served static (no
  widget-driven structural variation).

::

    import streamlit as st
    from wren.genbi.panel import cube_panel, raw_panel

    # Interactive, cube-backed:
    dim = st.selectbox("Group by", ["region", "category"])
    cube_panel(
        cube="sales",
        measures=["revenue"],
        dimensions=[dim],
        chart="bar",
        title="Revenue",
    )

    # Escape hatch for complex, static queries:
    raw_panel(
        sql="SELECT month, revenue, AVG(revenue) OVER (...) FROM ...",
        chart="line", x="month", y="revenue",
    )
"""

import streamlit as st

st.set_page_config(page_title="{name}", layout="wide")
st.title("{name}")
st.caption("Generated by Wren GenBI — edit apps/{name}/app.py to build this out.")
st.write("This app is live. Replace this stub with cube_panel(...) calls.")
