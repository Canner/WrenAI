{
  "name": "wren-ui",
  "version": "0.32.2",
  "private": true,
  "scripts": {
    "dev": "TZ=UTC next dev",
    "dev:3001": "PORT=3001 PG_URL=postgres://postgres:postgres@127.0.0.1:9432/wrenai TZ=UTC next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 next build",
    "start": "TZ=UTC node .next/standalone/server.js",
    "lint": "yarn check-types && eslint --max-warnings=0 --ext .js,.jsx,.ts,.tsx src next.config.js",
    "check-pages-routes": "node scripts/check_pages_routes.mjs",
    "deps:audit": "node scripts/audit_frontend_dependencies.mjs",
    "deps:audit:check": "yarn deps:audit && yarn dedupe --check && yarn install --mode=skip-build",
    "deps:why:cron-parser": "yarn why cron-parser",
    "lint:changed": "node scripts/lint_changed.mjs",
    "lint:changed:fix": "node scripts/lint_changed.mjs --fix",
    "lint:changed:staged": "node scripts/lint_changed.mjs --staged",
    "test": "jest",
    "test:e2e": "npx playwright install chromium && npx playwright test",
    "check-types": "tsc --noEmit",
    "check-types:strict-partial": "tsc --noEmit -p tsconfig.strict.partial.json",
    "migrate": "yarn knex migrate:latest",
    "migrate:3001": "PG_URL=postgres://postgres:postgres@127.0.0.1:9432/wrenai yarn knex migrate:latest",
    "rollback": "yarn knex migrate:rollback",
    "backfill:principal-role-bindings": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/backfill_principal_role_bindings.ts",
    "repair:orphan-workspace-bindings": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/clean_orphan_workspace_role_bindings.ts",
    "migrate:workspace-roles-owner-viewer": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/migrate_workspace_roles_to_owner_viewer.ts",
    "backfill:legacy-project-connectors": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/backfill_legacy_projects_to_connectors.ts",
    "re-encrypt-secrets": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/re_encrypt_secrets.ts"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cron-parser": "^5.1.1",
    "fast-xml-parser": "4.5.4",
    "knex": "^3.1.0",
    "lodash": "^4.17.23",
    "log4js": "^6.9.1",
    "next": "15.5.15",
    "pg": "^8.8.0",
    "posthog-node": "^4.3.2",
    "sql-formatter": "^15.3.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@ant-design/cssinjs": "2.1.2",
    "@ant-design/icons": "6.1.1",
    "@next/bundle-analyzer": "15.5.15",
    "@playwright/test": "^1.55.2",
    "@types/jest": "29.4.4",
    "@types/lodash": "^4.14.202",
    "@types/node": "18.16.9",
    "@types/pg": "^8.6.5",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/react-grid-layout": "^1.3.5",
    "@types/styled-components": "5.1.26",
    "@typescript-eslint/eslint-plugin": "6.18.0",
    "@typescript-eslint/parser": "6.18.0",
    "ace-builds": "^1.32.3",
    "antd": "6.3.6",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "driver.js": "^1.3.1",
    "eslint": "^8",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "29.4.3",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "next-with-less": "^3.0.1",
    "posthog-js": "^1.205.0",
    "prettier": "^3.2.5",
    "react": "18.2.0",
    "react-ace": "^10.1.0",
    "react-dom": "18.2.0",
    "react-grid-layout": "^1.5.0",
    "react-is": "18.2.0",
    "react-markdown": "^9.0.1",
    "reactflow": "11.10.3",
    "remark-gfm": "^4.0.0",
    "styled-components": "5.3.6",
    "styled-icons": "^10.47.0",
    "ts-jest": "29.1.1",
    "ts-node": "9.1.1",
    "typescript": "5.2.2",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.2.0"
  },
  "resolutions": {
    "ws": "8.17.1",
    "axios": "1.13.5",
    "tar-fs": "2.1.4",
    "tmp": "0.2.4",
    "glob": "10.5.0",
    "js-yaml": "4.1.1",
    "jws": "4.0.1",
    "tar": "7.5.8",
    "vega-selections": "6.1.2",
    "vega-functions": "6.1.1",
    "fast-xml-parser": "4.5.4",
    "lodash": "4.17.23",
    "minimatch": "4.2.5",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0"
  },
  "_moduleAliases": {
    "@server": "src/server"
  },
  "packageManager": "yarn@4.5.3"
}
